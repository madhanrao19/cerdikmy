# =============================================================================
# cerdikMY — environment configuration (on-prem .NET 10 + SQL Server)
# Copy to `.env` for Docker Compose, or mirror into appsettings.*.json / user-secrets.
#
# The values below are DEVELOPMENT DEFAULTS — they let the local stack boot out of
# the box. They are NOT safe for a real deployment.
#
# ── PRODUCTION CHECKLIST ─────────────────────────────────────────────────────
#   1. Run  ./scripts/generate-secrets.sh  to write strong random values for the
#      SQL Server sa password, MinIO keys and JWT secrets into .env.
#   2. Set  ALLOW_DEV_DEFAULT_SECRETS="false"  (the app refuses to start in
#      Production with any built-in default credential while this is false).
#   3. Set  SEED_DEMO_DATA="false"  so demo accounts/content are NOT created, and
#      set BOOTSTRAP_ADMIN_EMAIL / BOOTSTRAP_ADMIN_PASSWORD to seed your real admin.
#   4. Fill the provider keys you use (AI / payments / SMTP) and keep .env out of
#      version control (chmod 600).
# =============================================================================

# ---- Database (SQL Server) ----
# EF Core / ADO connection string. On-prem self-hosted SQL Server 2022/2025.
# DEV DEFAULT — replace the password (and MSSQL_SA_PASSWORD) for production.
DATABASE_URL="Server=localhost,1433;Database=cerdikmy;User Id=sa;Password=Cerdik!Passw0rd;TrustServerCertificate=True;Encrypt=False"
MSSQL_SA_PASSWORD="Cerdik!Passw0rd"

# ---- Secret-safety gate ----
# When ASPNETCORE_ENVIRONMENT=Production, the API refuses to start if any built-in
# development default credential is still in use. The local prod-parity compose
# stack sets this to "true" to opt out; a real deployment MUST set it to "false".
ALLOW_DEV_DEFAULT_SECRETS="true"

# ---- Cache / Jobs ----
# Hangfire uses SQL Server storage (no Redis needed). REDIS_URL is optional and
# only consumed if you switch the cache provider to Redis.
REDIS_URL="redis://localhost:6379"

# ---- App URLs ----
NEXT_PUBLIC_APP_URL="http://localhost:5080"     # Blazor web app public URL
# Extra origins allowed for lesson media in the web app's CSP (space-separated). Prod https is
# allowed by default; add a dev MinIO http origin so local media renders.
MEDIA_CSP_ORIGINS="http://localhost:9000"
API_BASE_URL="http://localhost:5081"            # ASP.NET Core API base URL

# ---- Cloudflare Tunnel (TLS at the edge, plain-HTTP origin; see docs/deployment-cloudflare.md) ----
# Set BEHIND_TLS_PROXY=true when serving through nginx + a Cloudflare Tunnel (or any TLS-terminating
# reverse proxy): the apps then trust X-Forwarded-* (real client IP + https scheme) and skip
# origin-side HTTPS redirect/HSTS. The docker-compose.cloudflare.yml overlay sets this for you.
BEHIND_TLS_PROXY=""                              # "true" to enable (blank = off, for local dev)
# Tunnel token from the Cloudflare Zero Trust dashboard (only needed with `--profile tunnel`).
TUNNEL_TOKEN=""
# For a tunnel deployment, set the public hostname here (drives the app URL, CORS and cookie domain):
#   NEXT_PUBLIC_APP_URL="https://app.yourdomain.my"
#   SESSION_COOKIE_DOMAIN="app.yourdomain.my"

# ---- Auth / JWT ----
# DEV DEFAULTS — run ./scripts/generate-secrets.sh to replace these for production.
JWT_ACCESS_SECRET="dev-access-secret-change-me-min-32-chars-long-000"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me-min-32-chars-long-00"
JWT_ISSUER="cerdikmy"
JWT_AUDIENCE="cerdikmy-clients"
JWT_ACCESS_TTL_MINUTES="15"
JWT_REFRESH_TTL_DAYS="30"
SESSION_COOKIE_DOMAIN="localhost"

# ---- Database initialization / seeding ----
# SEED_ON_STARTUP=false disables all startup schema work (use the one-shot
#   `dotnet Cerdik.Api.dll --migrate` instead). Default: enabled.
# SEED_DEMO_DATA controls the demo accounts/content seeder. It defaults to ON
#   outside Production and OFF in Production. Set "true"/"false" to force it.
# BOOTSTRAP_ADMIN_* creates your first real admin on an empty database (runs in
#   every environment when both are set, and never overwrites an existing user).
SEED_ON_STARTUP="true"
SEED_DEMO_DATA="true"
BOOTSTRAP_ADMIN_EMAIL=""
BOOTSTRAP_ADMIN_PASSWORD=""
BOOTSTRAP_ADMIN_NAME="Platform Admin"

# ---- Object storage (S3-compatible; MinIO for dev, Azure Blob for prod) ----
STORAGE_PROVIDER="s3"                            # s3 | azure
S3_ENDPOINT="http://localhost:9000"
S3_REGION="ap-southeast-1"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="cerdik-media"
AZURE_STORAGE_CONNECTION_STRING=""

# ---- AI providers (one interface, pluggable adapter) ----
AI_PROVIDER="openai"                             # openai | azureopenai | anthropic | mock
OPENAI_API_KEY=""
OPENAI_CHAT_MODEL="gpt-4o-mini"
OPENAI_EMBED_MODEL="text-embedding-3-small"
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_DEPLOYMENT=""
ANTHROPIC_API_KEY=""
ANTHROPIC_CHAT_MODEL="claude-sonnet-4-6"

# ---- Payments (Malaysia-first: Billplz / Curlec, plus Stripe) ----
PAYMENT_PROVIDER="billplz"                       # billplz | curlec | stripe
BILLPLZ_API_KEY=""
BILLPLZ_COLLECTION_ID=""
CURLEC_KEY_ID=""
CURLEC_KEY_SECRET=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ---- Mail ----
MAIL_FROM="cerdikMY <no-reply@cerdik.my>"
SMTP_URL="smtp://localhost:1025"

# ---- Observability (OpenTelemetry OTLP) ----
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"
OTEL_SERVICE_NAME="cerdikmy-api"

# ---- Feature flags (comma-separated overrides; see Application/FeatureFlags) ----
FEATURE_FLAGS="lang.zh=true,lang.ta=true,dlp.science=true,dlp.math=false"

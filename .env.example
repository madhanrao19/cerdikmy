# =============================================================================
# cerdikMY — environment configuration (on-prem .NET 10 + SQL Server)
# Copy to `.env` for Docker Compose, or mirror into appsettings.*.json / user-secrets.
# =============================================================================

# ---- Database (SQL Server) ----
# EF Core / ADO connection string. On-prem self-hosted SQL Server 2022/2025.
DATABASE_URL="Server=localhost,1433;Database=cerdikmy;User Id=sa;Password=Cerdik!Passw0rd;TrustServerCertificate=True;Encrypt=False"

# ---- Cache / Jobs ----
# Hangfire uses SQL Server storage (no Redis needed). REDIS_URL is optional and
# only consumed if you switch the cache provider to Redis.
REDIS_URL="redis://localhost:6379"

# ---- App URLs ----
NEXT_PUBLIC_APP_URL="http://localhost:5080"     # Blazor web app public URL
# Extra origins allowed for lesson media in the web app's CSP (space-separated). Prod https is
# allowed by default; add a dev MinIO http origin so local media renders.
MEDIA_CSP_ORIGINS="http://localhost:9000"
API_BASE_URL="http://localhost:5081"            # ASP.NET Core API base URL

# ---- Auth / JWT ----
JWT_ACCESS_SECRET="dev-access-secret-change-me-min-32-chars-long-000"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me-min-32-chars-long-00"
JWT_ISSUER="cerdikmy"
JWT_AUDIENCE="cerdikmy-clients"
JWT_ACCESS_TTL_MINUTES="15"
JWT_REFRESH_TTL_DAYS="30"
SESSION_COOKIE_DOMAIN="localhost"

# ---- Object storage (S3-compatible; MinIO for dev, Azure Blob for prod) ----
STORAGE_PROVIDER="s3"                            # s3 | azure
S3_ENDPOINT="http://localhost:9000"
S3_REGION="ap-southeast-1"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="cerdik-media"
AZURE_STORAGE_CONNECTION_STRING=""

# ---- AI providers (one interface, pluggable adapter) ----
AI_PROVIDER="openai"                             # openai | azureopenai | anthropic | mock
OPENAI_API_KEY=""
OPENAI_CHAT_MODEL="gpt-4o-mini"
OPENAI_EMBED_MODEL="text-embedding-3-small"
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_DEPLOYMENT=""
ANTHROPIC_API_KEY=""
ANTHROPIC_CHAT_MODEL="claude-sonnet-4-6"

# ---- Payments (Malaysia-first: Billplz / Curlec, plus Stripe) ----
PAYMENT_PROVIDER="billplz"                       # billplz | curlec | stripe
BILLPLZ_API_KEY=""
BILLPLZ_COLLECTION_ID=""
CURLEC_KEY_ID=""
CURLEC_KEY_SECRET=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ---- Mail ----
MAIL_FROM="cerdikMY <no-reply@cerdik.my>"
SMTP_URL="smtp://localhost:1025"

# ---- Observability (OpenTelemetry OTLP) ----
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4317"
OTEL_SERVICE_NAME="cerdikmy-api"

# ---- Feature flags (comma-separated overrides; see Application/FeatureFlags) ----
FEATURE_FLAGS="lang.zh=true,lang.ta=true,dlp.science=true,dlp.math=false"

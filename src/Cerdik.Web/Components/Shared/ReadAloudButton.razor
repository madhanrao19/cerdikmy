@inject IJSRuntime JS
@inject IUiText T
@implements IAsyncDisposable

@* Read-aloud toggle using the browser Web Speech API (see wwwroot/js/tts.js). Degrades to a
   no-op where speech synthesis is unavailable. Lang is the app code (en|ms|zh|ta). *@
<button type="button" class="read-aloud no-print" @onclick="ToggleAsync"
        aria-pressed="@_speaking" title="@(_speaking ? T["read.stop"] : T["read.listen"])">
    <span aria-hidden="true">@(_speaking ? "⏹" : "🔊")</span>
    <span>@(_speaking ? T["read.stop"] : T["read.listen"])</span>
</button>

<style>
    .read-aloud { display: inline-flex; align-items: center; gap: .35rem; border: 1px solid #cbd5e1;
        background: #fff; border-radius: 9999px; padding: .3rem .8rem; font-size: .8rem; font-weight: 600;
        color: #334155; cursor: pointer; }
    .read-aloud:hover { border-color: var(--brand-400); color: var(--brand-700); }
    .read-aloud[aria-pressed="true"] { background: var(--brand-50); border-color: var(--brand-400); color: var(--brand-700); }
    .read-aloud:focus-visible { outline: 2px solid var(--brand-500); outline-offset: 2px; }
</style>

@code {
    [Parameter, EditorRequired] public string Text { get; set; } = "";
    /// <summary>App language code (en | ms | zh | ta). Defaults to the current UI language.</summary>
    [Parameter] public string? Lang { get; set; }

    private bool _speaking;

    private async Task ToggleAsync()
    {
        if (_speaking)
        {
            await StopAsync();
            return;
        }
        if (string.IsNullOrWhiteSpace(Text)) return;
        _speaking = true;
        await JS.InvokeVoidAsync("cerdikSpeak", Text, ToBcp47(Lang ?? T.Lang));
    }

    private async Task StopAsync()
    {
        _speaking = false;
        await JS.InvokeVoidAsync("cerdikStopSpeak");
    }

    private static string ToBcp47(string appLang) => appLang switch
    {
        "ms" => "ms-MY",
        "zh" => "zh-CN",
        "ta" => "ta-IN",
        _ => "en-GB",
    };

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("cerdikStopSpeak"); }
        catch (Exception) { /* circuit already gone */ }
    }
}

@implements IAsyncDisposable
@inject TutorClient Tutor
@inject MarkdownService Markdown
@inject IUiText T

@* Streaming AI tutor chat. Sends messages via the SSE TutorClient, appending
   "delta" chunks live and finalising with citations, mastery and risk. Includes
   a needs-review banner and an accessible, labelled composer. *@
<section class="tutor-panel" aria-label="AI tutor conversation">
    @if (_needsReview)
    {
        <div class="review-banner" role="alert">
            <span aria-hidden="true">🛡️</span>
            <p>@T["tutor.review_banner"]</p>
        </div>
    }

    <div class="tutor-log" role="log" aria-live="polite" aria-label="Messages" @ref="_logRef">
        @if (Messages.Count == 0 && !_streaming)
        {
            <div class="tutor-empty">
                <p class="empty-emoji" aria-hidden="true">💬</p>
                <p>@T["tutor.empty"]</p>
            </div>
        }

        @foreach (var m in Messages)
        {
            <div class="msg msg-@(m.IsUser ? "user" : "assistant")">
                <div class="msg-role">@(m.IsUser ? T["tutor.you"] : T["tutor.tutor"])</div>
                <div class="msg-bubble">
                    @if (m.IsUser)
                    {
                        <p>@m.Text</p>
                    }
                    else
                    {
                        <div class="prose">@Markdown.ToMarkup(m.Text)</div>
                        @if (m.Citations.Count > 0)
                        {
                            <div class="msg-citations" aria-label="@T["tutor.sources"]">
                                <span class="sources-label" aria-hidden="true">@T["tutor.sources"]</span>
                                @foreach (var c in m.Citations)
                                {
                                    <CitationPill Citation="c" />
                                }
                            </div>
                        }
                        @if (m.MasterySignal is { } band)
                        {
                            <div class="msg-mastery"><MasteryBadge Band="band" /></div>
                        }
                        <div class="msg-read no-print"><ReadAloudButton Text="@StripMarkdown(m.Text)" /></div>
                    }
                </div>
            </div>
        }

        @if (_streaming)
        {
            <div class="msg msg-assistant">
                <div class="msg-role">@T["tutor.tutor"]</div>
                <div class="msg-bubble">
                    <div class="prose">@Markdown.ToMarkup(_streamingText.ToString())</div>
                    <span class="typing" aria-hidden="true"><span></span><span></span><span></span></span>
                    <span class="sr-only" role="status">@T["tutor.replying"]</span>
                </div>
            </div>
        }
    </div>

    @if (_error is not null)
    {
        <p class="tutor-error" role="alert">@_error</p>
    }

    <form class="tutor-composer" @onsubmit="SendAsync" @onsubmit:preventDefault>
        <label class="sr-only" for="tutor-input">@T["tutor.input_label"]</label>
        <textarea id="tutor-input" class="tutor-input" rows="2"
                  placeholder="@T["tutor.placeholder"]" value="@_input"
                  @oninput="e => _input = e.Value?.ToString() ?? string.Empty"
                  @onkeydown="OnKeyDown" disabled="@(_streaming || SessionId is null)"></textarea>
        <button type="submit" class="btn-accent tutor-send"
                disabled="@(_streaming || SessionId is null || string.IsNullOrWhiteSpace(_input))">
            @(_streaming ? "…" : T["tutor.send"])
        </button>
    </form>
    <p class="composer-hint">@T["tutor.hint"]</p>
</section>

<style>
    .tutor-panel { display: flex; flex-direction: column; height: 100%; min-height: 28rem; background: #f6f8fc; border: 1px solid #e8edf6; border-radius: 1rem; overflow: hidden; }
    .review-banner { display: flex; align-items: center; gap: .6rem; background: #fffbeb; border-bottom: 1px solid #fde68a; color: #92400e; padding: .6rem 1rem; font-size: .85rem; }
    .review-banner p { margin: 0; }
    .tutor-log { flex: 1 1 auto; overflow-y: auto; padding: 1rem; display: flex; flex-direction: column; gap: 1rem; }
    .tutor-empty { margin: auto; text-align: center; color: #94a3b8; }
    .empty-emoji { font-size: 2rem; }
    .msg { display: flex; flex-direction: column; gap: .25rem; max-width: 90%; }
    .msg-user { align-self: flex-end; align-items: flex-end; }
    .msg-assistant { align-self: flex-start; }
    .msg-role { font-size: .7rem; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: .03em; }
    .msg-bubble { padding: .75rem .9rem; border-radius: .9rem; font-size: .9rem; }
    .msg-user .msg-bubble { background: var(--brand-600); color: #fff; border-bottom-right-radius: .25rem; box-shadow: 0 2px 8px -2px rgba(33,82,217,.4); }
    .msg-user .msg-bubble p { margin: 0; }
    .msg-assistant .msg-bubble { background: #fff; color: #1e293b; border: 1px solid #e8edf6; border-bottom-left-radius: .25rem; box-shadow: 0 1px 2px rgba(15,23,42,.04); }
    .msg-citations { display: flex; flex-wrap: wrap; align-items: center; gap: .35rem; margin-top: .6rem; padding-top: .6rem; border-top: 1px solid #eef2f9; }
    .sources-label { font-size: .62rem; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; color: #94a3b8; margin-right: .15rem; }
    .msg-mastery { margin-top: .5rem; }
    .msg-read { margin-top: .5rem; }
    .typing { display: inline-flex; gap: 3px; margin-top: .35rem; }
    .typing span { width: 6px; height: 6px; border-radius: 9999px; background: #94a3b8; animation: typing 1s infinite; }
    .typing span:nth-child(2) { animation-delay: .15s; }
    .typing span:nth-child(3) { animation-delay: .3s; }
    @@keyframes typing { 0%, 60%, 100% { opacity: .3; } 30% { opacity: 1; } }
    .tutor-error { padding: .5rem 1rem; color: #b91c1c; font-size: .85rem; margin: 0; }
    .tutor-composer { display: flex; gap: .5rem; padding: .75rem; border-top: 1px solid #e8edf6; background: #fff; }
    .tutor-input { flex: 1 1 auto; resize: none; border: 1px solid #d6deeb; border-radius: .75rem; padding: .6rem .85rem; font-size: .9rem; font-family: inherit; }
    .tutor-input:focus { outline: none; border-color: var(--brand-500); box-shadow: 0 0 0 3px rgba(52,112,244,.18); }
    .tutor-send { align-self: stretch; border-radius: .75rem; min-width: 4rem; }
    .composer-hint { padding: .5rem .75rem .6rem; font-size: .72rem; color: #94a3b8; margin: 0; background: #fff; }
</style>

@code {
    [Parameter] public Guid? SessionId { get; set; }

    /// <summary>Optional pre-existing messages (e.g. when resuming a session).</summary>
    [Parameter] public IReadOnlyList<TutorMessageDto>? InitialMessages { get; set; }

    /// <summary>Raised when a reply finalises (host may persist or react).</summary>
    [Parameter] public EventCallback<TutorReplyDto> OnReplyReceived { get; set; }

    private sealed class ChatMessage
    {
        public bool IsUser { get; init; }
        public string Text { get; set; } = "";
        public IReadOnlyList<CitationDto> Citations { get; set; } = Array.Empty<CitationDto>();
        public MasteryBand? MasterySignal { get; set; }
    }

    private readonly List<ChatMessage> Messages = new();
    private readonly System.Text.StringBuilder _streamingText = new();
    private string _input = "";
    private bool _streaming;
    private bool _needsReview;
    private string? _error;
    private ElementReference _logRef;
    private CancellationTokenSource? _cts;

    protected override void OnParametersSet()
    {
        if (InitialMessages is { Count: > 0 } && Messages.Count == 0)
        {
            foreach (var m in InitialMessages)
            {
                Messages.Add(new ChatMessage
                {
                    IsUser = m.Role == TutorMessageRole.User,
                    Text = m.Content,
                    Citations = m.Citations,
                    MasterySignal = m.MasterySignal,
                });
                if (m.NeedsReview) _needsReview = true;
            }
        }
    }

    private static string StripMarkdown(string md) =>
        System.Text.RegularExpressions.Regex.Replace(md, @"[#*_`>~\[\]()]|!\[|\]\(.*?\)", " ").Trim();

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendAsync();
        }
    }

    private async Task SendAsync()
    {
        if (_streaming || SessionId is not { } sessionId) return;
        var text = _input.Trim();
        if (string.IsNullOrEmpty(text)) return;

        _error = null;
        _input = "";
        Messages.Add(new ChatMessage { IsUser = true, Text = text });
        _streamingText.Clear();
        _streaming = true;
        StateHasChanged();

        _cts = new CancellationTokenSource();
        try
        {
            TutorReplyDto? final = null;
            await foreach (var evt in Tutor.StreamMessageAsync(sessionId, text, _cts.Token))
            {
                if (evt.Kind == TutorStreamEventKind.Delta && evt.Delta is { } delta)
                {
                    _streamingText.Append(delta);
                    StateHasChanged();
                }
                else if (evt.Kind == TutorStreamEventKind.Final && evt.Final is { } reply)
                {
                    final = reply;
                }
            }

            // Materialise the assistant message from the final event (or accumulated text).
            var answer = final?.AnswerMarkdown is { Length: > 0 } md ? md : _streamingText.ToString();
            Messages.Add(new ChatMessage
            {
                IsUser = false,
                Text = answer,
                Citations = final?.Citations ?? Array.Empty<CitationDto>(),
                MasterySignal = final?.MasterySignal,
            });

            if (final?.NeedsReview == true) _needsReview = true;
            if (final is not null) await OnReplyReceived.InvokeAsync(final);
        }
        catch (OperationCanceledException)
        {
            // Disposed mid-stream; ignore.
        }
        catch (Exception ex)
        {
            _error = ex is ApiException api ? api.Message : T["tutor.unavailable"];
        }
        finally
        {
            _streaming = false;
            _streamingText.Clear();
            StateHasChanged();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_cts is not null)
        {
            await _cts.CancelAsync();
            _cts.Dispose();
        }
    }
}

@* Renders a lesson's ordered blocks. Activities are rendered separately by the
   page (via QuizCard) so the renderer stays focused on instructional content. *@
<article class="lesson-renderer">
    <header class="lesson-head">
        <h1 class="lesson-title">@Lesson.Title</h1>
        @if (!string.IsNullOrWhiteSpace(Lesson.Summary))
        {
            <p class="lesson-summary">@Lesson.Summary</p>
        }
        <p class="lesson-meta">
            <span aria-hidden="true">⏱️</span>
            <span>@Lesson.EstimatedMinutes min</span>
            <span aria-hidden="true">·</span>
            <span>@Lesson.Blocks.Count sections</span>
        </p>
        <div class="lesson-actions"><ReadAloudButton Text="@ReadText()" /></div>
    </header>

    <div class="lesson-body">
        @foreach (var block in Lesson.Blocks.OrderBy(b => b.SortOrder))
        {
            <div class="lesson-section">
                <MediaBlockRenderer Block="block" />
            </div>
        }
        @if (Lesson.Blocks.Count == 0)
        {
            <p class="text-slate-500">This lesson has no content yet.</p>
        }
    </div>
</article>

<style>
    .lesson-renderer { max-width: 46rem; }
    .lesson-head { margin-bottom: 1.5rem; }
    .lesson-title { font-size: 1.75rem; font-weight: 700; color: #0f172a; }
    .lesson-summary { margin-top: .5rem; color: #475569; font-size: 1.05rem; }
    .lesson-meta { display: flex; align-items: center; gap: .5rem; margin-top: .75rem; font-size: .85rem; color: #64748b; }
    .lesson-actions { margin-top: .85rem; }
    .lesson-body { display: flex; flex-direction: column; gap: 1.5rem; }
</style>

@code {
    [Parameter, EditorRequired] public LessonDto Lesson { get; set; } = default!;

    /// <summary>Plain-text version of the lesson for read-aloud: title, summary and each text block,
    /// with light Markdown punctuation stripped so it isn't read out as symbols.</summary>
    private string ReadText()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine(Lesson.Title);
        if (!string.IsNullOrWhiteSpace(Lesson.Summary)) sb.AppendLine(Lesson.Summary);
        foreach (var b in Lesson.Blocks.OrderBy(x => x.SortOrder))
        {
            if (!string.IsNullOrWhiteSpace(b.Markdown)) sb.AppendLine(StripMarkdown(b.Markdown!));
        }
        return sb.ToString();
    }

    private static string StripMarkdown(string md) =>
        System.Text.RegularExpressions.Regex.Replace(md, @"[#*_`>~\[\]()]|!\[|\]\(.*?\)", " ").Trim();
}

@* A single source citation rendered as a pill. The snippet is exposed via the
   title attribute and an aria-label for assistive tech. *@
<span class="citation-pill" title="@Citation.Snippet"
      aria-label="@($"Source {Citation.Ordinal}: {Citation.LessonTitle}")">
    <span class="citation-ordinal" aria-hidden="true">@Citation.Ordinal</span>
    <span class="citation-title">@Citation.LessonTitle</span>
</span>

<style>
    .citation-pill { display: inline-flex; align-items: center; gap: .35rem; max-width: 16rem; font-size: .72rem; font-weight: 500; color: var(--brand-800); background: var(--brand-50); border: 1px solid var(--brand-200); border-radius: 9999px; padding: .15rem .55rem; }
    .citation-ordinal { display: inline-flex; align-items: center; justify-content: center; min-width: 1.1rem; height: 1.1rem; border-radius: 9999px; background: var(--brand-600); color: #fff; font-size: .65rem; font-weight: 700; }
    .citation-title { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
</style>

@code {
    [Parameter, EditorRequired] public CitationDto Citation { get; set; } = default!;
}

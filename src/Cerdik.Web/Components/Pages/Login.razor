@page "/login"
@using System.ComponentModel.DataAnnotations
@inject AuthStateService Auth
@inject NavigationManager Nav

<PageTitle>Sign in — cerdikMY</PageTitle>

<div class="auth-page">
    <div class="auth-brand-block">
        <span class="logo-mark logo-mark-lg" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 3 1.5 8.5 12 14l9-4.7V15h2V8.5L12 3Z" fill="currentColor"/>
                <path d="M5 11.3V15c0 1.7 3.1 3 7 3s7-1.3 7-3v-3.7l-7 3.7-7-3.7Z" fill="currentColor"/>
            </svg>
        </span>
        <div class="auth-wordmark">cerdik<span class="brand-accent">MY</span></div>
        <div class="auth-tag">Malaysian Homeschooling Portal</div>
    </div>
    <div class="auth-card">
        <h1 class="auth-title">Sign in</h1>
        <p class="auth-sub">Welcome back! Please enter your details.</p>

        <EditForm Model="_model" OnValidSubmit="SubmitAsync" FormName="login">
            <DataAnnotationsValidator />

            @if (_error is not null)
            {
                <div class="auth-error" role="alert">@_error</div>
            }

            <div class="field">
                <label class="label" for="login-email">Email</label>
                <InputText id="login-email" class="input" @bind-Value="_model.Email"
                           autocomplete="email" aria-describedby="login-email-err" />
                <ValidationMessage For="() => _model.Email" id="login-email-err" role="alert" />
            </div>

            <div class="field">
                <label class="label" for="login-password">Password</label>
                <InputText id="login-password" type="password" class="input" @bind-Value="_model.Password"
                           autocomplete="current-password" aria-describedby="login-password-err" />
                <ValidationMessage For="() => _model.Password" id="login-password-err" role="alert" />
            </div>

            <button type="submit" class="btn-accent btn-lg w-full" disabled="@_busy">
                @(_busy ? "Signing in…" : "Sign in →")
            </button>
        </EditForm>

        <p class="auth-foot">
            New to cerdikMY? <a href="/register">Create an account</a>
        </p>
    </div>
    <p class="auth-meta">🛡 Secure access &nbsp;·&nbsp; 🌐 KPM aligned</p>
</div>

<style>
    .auth-page { min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 1.5rem; background: linear-gradient(160deg, #eef5ff 0%, #f6f8fc 45%, #fff 100%); }
    .auth-brand-block { text-align: center; margin-bottom: 1.5rem; }
    .logo-mark-lg { width: 3.25rem; height: 3.25rem; border-radius: .9rem; }
    .logo-mark-lg svg { width: 1.8rem; height: 1.8rem; }
    .auth-wordmark { font-size: 1.85rem; font-weight: 800; color: #0f172a; letter-spacing: -.02em; margin-top: .6rem; }
    .auth-tag { font-size: .72rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: #94a3b8; margin-top: .15rem; }
    .auth-card { width: 100%; max-width: 27rem; background: #fff; border: 1px solid #e8edf6; border-radius: 1.25rem; padding: 2rem; box-shadow: 0 18px 48px -20px rgba(15,23,42,.3); }
    .auth-title { font-size: 1.6rem; font-weight: 800; color: #0f172a; }
    .auth-sub { color: #64748b; margin-top: .25rem; margin-bottom: 1.5rem; }
    .field { margin-bottom: 1.1rem; }
    .auth-error { background: #fef2f2; border: 1px solid #fecaca; color: #b91c1c; padding: .6rem .75rem; border-radius: .6rem; font-size: .85rem; margin-bottom: 1rem; }
    .auth-foot { margin-top: 1.5rem; font-size: .9rem; color: #475569; text-align: center; }
    .auth-foot a { color: var(--accent-600); font-weight: 700; }
    .auth-meta { margin-top: 1.25rem; font-size: .72rem; font-weight: 600; letter-spacing: .06em; text-transform: uppercase; color: #94a3b8; }
    .w-full { width: 100%; }
</style>

@code {
    [SupplyParameterFromQuery] public string? ReturnUrl { get; set; }

    private readonly LoginModel _model = new();
    private bool _busy;
    private string? _error;

    private async Task SubmitAsync()
    {
        _error = null;
        _busy = true;
        try
        {
            await Auth.LoginAsync(_model.Email, _model.Password);
            NavigatePostLogin();
        }
        catch (ApiException ex)
        {
            _error = ex.IsUnauthorized
                ? "The email or password you entered is incorrect."
                : ex.Message;
        }
        catch (Exception)
        {
            _error = "We couldn't reach the server. Please try again.";
        }
        finally
        {
            _busy = false;
        }
    }

    private void NavigatePostLogin()
    {
        if (!string.IsNullOrWhiteSpace(ReturnUrl) && ReturnUrl.StartsWith('/'))
        {
            Nav.NavigateTo(ReturnUrl, forceLoad: false);
            return;
        }
        Nav.NavigateTo("/", forceLoad: false);
    }

    private sealed class LoginModel
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Password is required.")]
        public string Password { get; set; } = "";
    }
}

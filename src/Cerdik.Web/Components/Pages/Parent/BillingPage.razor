@page "/parent/billing"
@inject ApiClient Api
@inject AuthStateService Auth
@inject NavigationManager Nav
@inject IUiText T

<PageTitle>@T["billing.title"] — cerdikMY</PageTitle>

<AppShell>
    <RoleGuard Roles="@(new[] { UserRole.Parent })">
        <h1 class="page-title">@T["billing.title"]</h1>
        <p class="page-sub mb-6">@T["billing.sub"]</p>

        @if (_loading)
        {
            <p class="text-slate-500" role="status">@T["billing.loading"]</p>
        }
        else if (_error is not null)
        {
            <div class="card" role="alert">
                <p class="text-rose-700">@_error</p>
                <button class="btn-secondary mt-4" @onclick="LoadAsync">@T["common.retry"]</button>
            </div>
        }
        else
        {
            @if (_subscription is not null)
            {
                <section class="card subscription" aria-label="Current subscription">
                    <div class="sub-head">
                        <div>
                            <h2 class="sub-plan">@_subscription.PlanName</h2>
                            <p class="sub-meta">
                                @BillingPlanCard.FormatPrice(_subscription.AmountCents, _subscription.Currency)
                                · @string.Format(T["billing.renews"], _subscription.CurrentPeriodEnd.LocalDateTime.ToString("d MMM yyyy"))
                            </p>
                        </div>
                        <span class="sub-status status-@_subscription.Status.ToString().ToLowerInvariant()">
                            @_subscription.Status
                        </span>
                    </div>
                </section>

                <h2 class="section-title mt-8">@T["billing.invoices"]</h2>
                @if (_subscription.Invoices.Count == 0)
                {
                    <p class="text-slate-500">@T["billing.no_invoices"]</p>
                }
                else
                {
                    <div class="table-scroll">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>@T["billing.col.number"]</th><th>@T["billing.col.status"]</th><th>@T["billing.col.amount"]</th>
                                    <th>@T["billing.col.issued"]</th><th>@T["billing.col.paid"]</th><th><span class="sr-only">@T["billing.col.actions"]</span></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var inv in _subscription.Invoices)
                                {
                                    <tr>
                                        <td>@inv.Number</td>
                                        <td><span class="inv-status status-@inv.Status.ToString().ToLowerInvariant()">@inv.Status</span></td>
                                        <td>@BillingPlanCard.FormatPrice(inv.AmountCents, inv.Currency)</td>
                                        <td>@inv.IssuedAt.LocalDateTime.ToString("d MMM yyyy")</td>
                                        <td>@(inv.PaidAt?.LocalDateTime.ToString("d MMM yyyy") ?? "—")</td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(inv.HostedUrl))
                                            {
                                                <a class="text-brand-600" href="@inv.HostedUrl" target="_blank" rel="noopener">@T["billing.view"]</a>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
            else
            {
                <div class="card" role="note">
                    <p>@T["billing.no_subscription"]</p>
                </div>
            }

            <h2 class="section-title mt-8">@T["billing.plans"]</h2>

            <div class="promo-row">
                <input class="input promo-input" placeholder="@T["billing.promo_placeholder"]" aria-label="@T["billing.promo_placeholder"]"
                       value="@_promoInput" @oninput="e => _promoInput = e.Value?.ToString() ?? string.Empty" />
                <button class="btn-secondary" @onclick="ApplyPromoAsync" disabled="@(_promoBusy || string.IsNullOrWhiteSpace(_promoInput))">
                    @(_promoBusy ? T["billing.checking"] : T["billing.apply"])
                </button>
            </div>
            @if (_promoDiscount > 0)
            {
                <p class="promo-ok" role="status">@string.Format(T["billing.promo_applied"], _promoDiscount)</p>
            }
            else if (_promoError is not null)
            {
                <p class="promo-err" role="alert">@_promoError</p>
            }

            @if (_checkoutError is not null)
            {
                <p class="text-rose-700 mb-3" role="alert">@_checkoutError</p>
            }
            <div class="plans-grid">
                @foreach (var (plan, i) in _plans.Select((p, i) => (p, i)))
                {
                    <BillingPlanCard Plan="plan"
                                     Highlighted="@(i == 1)"
                                     IsCurrent="@(_subscription?.PlanCode == plan.Code)"
                                     Disabled="@(_checkoutPlan == plan.Code)"
                                     SelectLabel="@(_subscription is null ? T["billing.subscribe"] : T["billing.switch_plan"])"
                                     OnSelect="CheckoutAsync" />
                }
            </div>
        }
    </RoleGuard>
</AppShell>

<style>
    .page-title { font-size: 1.6rem; font-weight: 700; color: #0f172a; }
    .page-sub { color: #64748b; margin-top: .25rem; }
    .section-title { font-size: 1.2rem; font-weight: 700; color: #0f172a; margin-bottom: 1rem; }
    .subscription { padding: 1.25rem; }
    .sub-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; }
    .sub-plan { font-size: 1.3rem; font-weight: 700; color: #0f172a; }
    .sub-meta { color: #64748b; margin-top: .25rem; }
    .sub-status, .inv-status { font-size: .75rem; font-weight: 600; padding: .2rem .6rem; border-radius: 9999px; text-transform: capitalize; }
    .status-active, .status-paid { background: #d1fae5; color: #065f46; }
    .status-trialing, .status-open { background: #dbeafe; color: #1e40af; }
    .status-pastdue, .status-uncollectible { background: #fef3c7; color: #92400e; }
    .status-canceled, .status-expired, .status-void { background: #f1f5f9; color: #475569; }
    .table-scroll { overflow-x: auto; border: 1px solid #e2e8f0; border-radius: .75rem; background: #fff; }
    .data-table { width: 100%; border-collapse: collapse; font-size: .875rem; }
    .data-table th { text-align: left; font-weight: 600; color: #475569; background: #f8fafc; padding: .6rem .85rem; border-bottom: 1px solid #e2e8f0; }
    .data-table td { padding: .6rem .85rem; border-bottom: 1px solid #f1f5f9; color: #334155; }
    .promo-row { display: flex; gap: .5rem; max-width: 24rem; margin-bottom: .5rem; }
    .promo-input { flex: 1 1 auto; }
    .promo-ok { color: #047857; font-weight: 600; font-size: .85rem; margin-bottom: .75rem; }
    .promo-err { color: #b91c1c; font-weight: 600; font-size: .85rem; margin-bottom: .75rem; }
    .plans-grid { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
    @@media (min-width: 768px) { .plans-grid { grid-template-columns: repeat(3, 1fr); } }
</style>

@code {
    private SubscriptionDto? _subscription;
    private IReadOnlyList<BillingPlanDto> _plans = Array.Empty<BillingPlanDto>();
    private bool _loading = true;
    private string? _error;
    private string? _checkoutError;
    private string? _checkoutPlan;

    private string _promoInput = "";
    private string? _appliedPromo;
    private int _promoDiscount;
    private bool _promoBusy;
    private string? _promoError;

    private async Task ApplyPromoAsync()
    {
        _promoBusy = true;
        _promoError = null;
        _promoDiscount = 0;
        _appliedPromo = null;
        try
        {
            var result = await Api.ValidatePromoAsync(_promoInput.Trim());
            if (result.Valid)
            {
                _appliedPromo = _promoInput.Trim();
                _promoDiscount = result.DiscountPercent;
            }
            else
            {
                _promoError = result.Reason switch
                {
                    "expired" => T["billing.promo_expired"],
                    "exhausted" => T["billing.promo_exhausted"],
                    _ => T["billing.promo_invalid"],
                };
            }
        }
        catch (Exception)
        {
            _promoError = T["billing.promo_error"];
        }
        finally
        {
            _promoBusy = false;
        }
    }

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            var dashboard = await Api.GetParentDashboardAsync();
            _subscription = dashboard.Subscription;
            _plans = await Api.GetBillingPlansAsync();
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
        }
        catch (Exception)
        {
            _error = T["billing.error"];
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task CheckoutAsync(BillingPlanDto plan)
    {
        _checkoutError = null;
        _checkoutPlan = plan.Code;
        try
        {
            var householdId = Auth.User?.HouseholdId
                ?? throw new InvalidOperationException("No household is associated with your account.");
            var returnUrl = new Uri(new Uri(Nav.BaseUri), "/parent/billing").ToString();
            var session = await Api.CreateCheckoutSessionAsync(
                new CheckoutSessionRequest(householdId, plan.Code, returnUrl, _appliedPromo));
            Nav.NavigateTo(session.CheckoutUrl, forceLoad: true);
        }
        catch (ApiException ex)
        {
            _checkoutError = ex.Message;
        }
        catch (Exception ex)
        {
            _checkoutError = ex.Message;
        }
        finally
        {
            _checkoutPlan = null;
        }
    }
}

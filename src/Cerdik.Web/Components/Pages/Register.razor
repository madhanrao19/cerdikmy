@page "/register"
@using System.ComponentModel.DataAnnotations
@inject AuthStateService Auth
@inject NavigationManager Nav

<PageTitle>Create account — cerdikMY</PageTitle>

<div class="auth-page">
    <div class="auth-brand-block">
        <span class="logo-mark logo-mark-lg" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 3 1.5 8.5 12 14l9-4.7V15h2V8.5L12 3Z" fill="currentColor"/>
                <path d="M5 11.3V15c0 1.7 3.1 3 7 3s7-1.3 7-3v-3.7l-7 3.7-7-3.7Z" fill="currentColor"/>
            </svg>
        </span>
        <div class="auth-wordmark">cerdik<span class="brand-accent">MY</span></div>
        <div class="auth-tag">Malaysian Homeschooling Portal</div>
    </div>
    <div class="auth-card">
        <h1 class="auth-title">Create an account</h1>
        <p class="auth-sub">Set up your household to start your children's learning journey.</p>

        <EditForm Model="_model" OnValidSubmit="SubmitAsync" FormName="register">
            <DataAnnotationsValidator />

            @if (_error is not null)
            {
                <div class="auth-error" role="alert">@_error</div>
            }

            <div class="field">
                <label class="label" for="reg-name">Full name</label>
                <InputText id="reg-name" class="input" @bind-Value="_model.FullName"
                           autocomplete="name" aria-describedby="reg-name-err" />
                <ValidationMessage For="() => _model.FullName" id="reg-name-err" role="alert" />
            </div>

            <div class="field">
                <label class="label" for="reg-household">Household name</label>
                <InputText id="reg-household" class="input" @bind-Value="_model.HouseholdName"
                           aria-describedby="reg-household-err" />
                <ValidationMessage For="() => _model.HouseholdName" id="reg-household-err" role="alert" />
            </div>

            <div class="field">
                <label class="label" for="reg-email">Email</label>
                <InputText id="reg-email" class="input" @bind-Value="_model.Email"
                           autocomplete="email" aria-describedby="reg-email-err" />
                <ValidationMessage For="() => _model.Email" id="reg-email-err" role="alert" />
            </div>

            <div class="field">
                <label class="label" for="reg-password">Password</label>
                <InputText id="reg-password" type="password" class="input" @bind-Value="_model.Password"
                           autocomplete="new-password" aria-describedby="reg-password-err" />
                <ValidationMessage For="() => _model.Password" id="reg-password-err" role="alert" />
            </div>

            <div class="field">
                <label class="label" for="reg-language">Preferred language</label>
                <InputSelect id="reg-language" class="input" @bind-Value="_model.PreferredLanguage">
                    @foreach (var lang in Enum.GetValues<Language>())
                    {
                        <option value="@lang">@FilterLabels.Language(lang)</option>
                    }
                </InputSelect>
            </div>

            <button type="submit" class="btn-accent btn-lg w-full" disabled="@_busy">
                @(_busy ? "Creating account…" : "Create account →")
            </button>
        </EditForm>

        <p class="auth-foot">
            Already have an account? <a href="/login">Sign in</a>
        </p>
    </div>
</div>

<style>
    .auth-page { min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 1.5rem; background: linear-gradient(160deg, #eef5ff 0%, #f6f8fc 45%, #fff 100%); }
    .auth-brand-block { text-align: center; margin-bottom: 1.5rem; }
    .logo-mark-lg { width: 3.25rem; height: 3.25rem; border-radius: .9rem; }
    .logo-mark-lg svg { width: 1.8rem; height: 1.8rem; }
    .auth-wordmark { font-size: 1.85rem; font-weight: 800; color: #0f172a; letter-spacing: -.02em; margin-top: .6rem; }
    .auth-tag { font-size: .72rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: #94a3b8; margin-top: .15rem; }
    .auth-card { width: 100%; max-width: 28rem; background: #fff; border: 1px solid #e8edf6; border-radius: 1.25rem; padding: 2rem; box-shadow: 0 18px 48px -20px rgba(15,23,42,.3); }
    .auth-title { font-size: 1.6rem; font-weight: 800; color: #0f172a; }
    .auth-sub { color: #64748b; margin-top: .25rem; margin-bottom: 1.5rem; }
    .field { margin-bottom: 1.1rem; }
    .auth-error { background: #fef2f2; border: 1px solid #fecaca; color: #b91c1c; padding: .6rem .75rem; border-radius: .6rem; font-size: .85rem; margin-bottom: 1rem; }
    .auth-foot { margin-top: 1.5rem; font-size: .9rem; color: #475569; text-align: center; }
    .auth-foot a { color: var(--accent-600); font-weight: 700; }
    .w-full { width: 100%; }
</style>

@code {
    private readonly RegisterModel _model = new();
    private bool _busy;
    private string? _error;

    private async Task SubmitAsync()
    {
        _error = null;
        _busy = true;
        try
        {
            await Auth.RegisterParentAsync(new RegisterParentRequest(
                _model.Email, _model.Password, _model.FullName, _model.HouseholdName,
                _model.PreferredLanguage.ToString()));
            Nav.NavigateTo("/parent", forceLoad: false);
        }
        catch (ApiException ex)
        {
            _error = ex.StatusCode == System.Net.HttpStatusCode.Conflict
                ? "An account with this email already exists."
                : ex.Message;
        }
        catch (Exception)
        {
            _error = "We couldn't reach the server. Please try again.";
        }
        finally
        {
            _busy = false;
        }
    }

    private sealed class RegisterModel
    {
        [Required(ErrorMessage = "Your full name is required.")]
        [StringLength(120, MinimumLength = 2)]
        public string FullName { get; set; } = "";

        [Required(ErrorMessage = "A household name is required.")]
        [StringLength(120, MinimumLength = 2)]
        public string HouseholdName { get; set; } = "";

        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Password is required.")]
        [StringLength(100, MinimumLength = 8, ErrorMessage = "Password must be at least 8 characters.")]
        public string Password { get; set; } = "";

        public Language PreferredLanguage { get; set; } = Language.BM;
    }
}

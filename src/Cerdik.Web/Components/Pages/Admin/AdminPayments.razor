@page "/admin/payments"
@inject ApiClient Api

<PageTitle>Payments — cerdikMY Admin</PageTitle>

<AppShell>
    <RoleGuard Roles="@(new[] { UserRole.Admin })">
        <h1 class="page-title">Payment &amp; webhook logs</h1>
        <p class="page-sub mb-6">Reconcile provider webhooks (Billplz, Curlec, Stripe).</p>

        @if (_loading)
        {
            <p class="text-slate-500" role="status">Loading payments…</p>
        }
        else if (_error is not null)
        {
            <div class="card" role="alert">
                <p class="text-rose-700">@_error</p>
                <button class="btn-secondary mt-4" @onclick="LoadAsync">Retry</button>
            </div>
        }
        else
        {
            <AdminDataTable TItem="WebhookLogDto" Items="_items"
                            SearchText="@(p => $"{p.Provider} {p.ProviderPaymentId} {p.Status}")"
                            SearchPlaceholder="Search by provider, id or status">
                <HeaderTemplate>
                    <th>Provider</th><th>Payment ID</th><th>Status</th><th>Amount</th><th>Processed</th>
                </HeaderTemplate>
                <RowTemplate Context="p">
                    <td><span class="role-pill">@p.Provider</span></td>
                    <td class="font-mono text-xs">@p.ProviderPaymentId</td>
                    <td><span class="state-@p.Status.ToString().ToLower()">@p.Status</span></td>
                    <td>@p.Currency @((p.AmountCents / 100m).ToString("0.00"))</td>
                    <td>@(p.ProcessedAt?.LocalDateTime.ToString("d MMM yyyy HH:mm") ?? "—")</td>
                </RowTemplate>
                <EmptyContent><p>No payments recorded yet.</p></EmptyContent>
            </AdminDataTable>
        }
    </RoleGuard>
</AppShell>

<style>
    .page-title { font-size: 1.6rem; font-weight: 700; color: #0f172a; }
    .page-sub { color: #64748b; margin-top: .25rem; }
    .role-pill { font-size: .72rem; font-weight: 600; background: var(--brand-50); color: var(--brand-700); padding: .1rem .5rem; border-radius: 9999px; }
    .state-succeeded { color: #047857; font-weight: 600; }
    .state-failed { color: #b91c1c; font-weight: 600; }
    .state-pending { color: #b45309; font-weight: 600; }
</style>

@code {
    private IReadOnlyList<WebhookLogDto> _items = Array.Empty<WebhookLogDto>();
    private bool _loading = true;
    private string? _error;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try { _items = await Api.GetPaymentsAsync(); }
        catch (ApiException ex) { _error = ex.Message; }
        catch (Exception) { _error = "We couldn't load payments. Please try again."; }
        finally { _loading = false; }
    }
}

@page "/admin/moderation"
@inject ApiClient Api

<PageTitle>Moderation — cerdikMY Admin</PageTitle>

<AppShell>
    <RoleGuard Roles="@(new[] { UserRole.Admin, UserRole.SafetyReviewer })">
        <h1 class="page-title">Moderation queue</h1>
        <p class="page-sub mb-6">Review AI tutor exchanges flagged for a trusted adult.</p>

        @if (_loading)
        {
            <p class="text-slate-500" role="status">Loading queue…</p>
        }
        else if (_error is not null)
        {
            <div class="card" role="alert">
                <p class="text-rose-700">@_error</p>
                <button class="btn-secondary mt-4" @onclick="LoadAsync">Retry</button>
            </div>
        }
        else if (_items.Count == 0)
        {
            <div class="card"><p>🎉 Nothing to review — the queue is clear.</p></div>
        }
        else
        {
            <div class="grid gap-4 sm:grid-cols-2">
                @foreach (var item in _items)
                {
                    <ModerationReviewCard Item="item"
                                          OnAllow="@(() => ReviewAsync(item, ModerationDecision.Allow))"
                                          OnBlock="@(() => ReviewAsync(item, ModerationDecision.Block))"
                                          OnEscalate="@(() => ReviewAsync(item, ModerationDecision.Escalate))" />
                }
            </div>
        }
    </RoleGuard>
</AppShell>

<style>
    .page-title { font-size: 1.6rem; font-weight: 700; color: #0f172a; }
    .page-sub { color: #64748b; margin-top: .25rem; }
</style>

@code {
    private List<ModerationQueueItemDto> _items = new();
    private bool _loading = true;
    private string? _error;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _items = (await Api.GetModerationQueueAsync()).ToList();
        }
        catch (ApiException ex) { _error = ex.Message; }
        catch (Exception) { _error = "We couldn't load the moderation queue. Please try again."; }
        finally { _loading = false; }
    }

    private async Task ReviewAsync(ModerationQueueItemDto item, ModerationDecision decision)
    {
        try
        {
            await Api.ReviewModerationAsync(item.EventId, decision, $"Reviewed: {decision}");
            _items.RemoveAll(i => i.EventId == item.EventId);
        }
        catch (Exception) { _error = "We couldn't save your decision. Please try again."; }
    }
}

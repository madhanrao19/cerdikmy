@page "/reset-password"
@using System.ComponentModel.DataAnnotations
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>Reset password — cerdikMY</PageTitle>

<div class="auth-page">
    <div class="auth-brand-block">
        <span class="logo-mark logo-mark-lg" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 3 1.5 8.5 12 14l9-4.7V15h2V8.5L12 3Z" fill="currentColor"/>
                <path d="M5 11.3V15c0 1.7 3.1 3 7 3s7-1.3 7-3v-3.7l-7 3.7-7-3.7Z" fill="currentColor"/>
            </svg>
        </span>
        <div class="auth-wordmark">cerdik<span class="brand-accent">MY</span></div>
        <div class="auth-tag">Malaysian Homeschooling Portal</div>
    </div>
    <div class="auth-card">
        <h1 class="auth-title">Set a new password</h1>
        <p class="auth-sub">Choose a strong password for your account.</p>

        @if (string.IsNullOrWhiteSpace(Token))
        {
            <div class="auth-error" role="alert">This reset link is missing its token. Request a new one.</div>
            <p class="auth-foot"><a href="/forgot-password">Request a reset link</a></p>
        }
        else if (_done)
        {
            <div class="auth-ok" role="status">Your password has been reset. You can now sign in.</div>
            <p class="auth-foot"><a href="/login">Go to sign in</a></p>
        }
        else
        {
            <EditForm Model="_model" OnValidSubmit="SubmitAsync" FormName="reset">
                <DataAnnotationsValidator />
                @if (_error is not null)
                {
                    <div class="auth-error" role="alert">@_error</div>
                }
                <div class="field">
                    <label class="label" for="rp-pw">New password</label>
                    <InputText id="rp-pw" type="password" class="input" @bind-Value="_model.Password"
                               autocomplete="new-password" aria-describedby="rp-pw-err" />
                    <ValidationMessage For="() => _model.Password" id="rp-pw-err" role="alert" />
                </div>
                <div class="field">
                    <label class="label" for="rp-pw2">Confirm new password</label>
                    <InputText id="rp-pw2" type="password" class="input" @bind-Value="_model.Confirm"
                               autocomplete="new-password" aria-describedby="rp-pw2-err" />
                    <ValidationMessage For="() => _model.Confirm" id="rp-pw2-err" role="alert" />
                </div>
                <button type="submit" class="btn-accent btn-lg w-full" disabled="@_busy">
                    @(_busy ? "Resetting…" : "Reset password →")
                </button>
            </EditForm>
        }
    </div>
</div>

<style>
    .auth-page { min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 1.5rem; background: linear-gradient(160deg, #eef5ff 0%, #f6f8fc 45%, #fff 100%); }
    .auth-brand-block { text-align: center; margin-bottom: 1.5rem; }
    .logo-mark-lg { width: 3.25rem; height: 3.25rem; border-radius: .9rem; }
    .logo-mark-lg svg { width: 1.8rem; height: 1.8rem; }
    .auth-wordmark { font-size: 1.85rem; font-weight: 800; color: #0f172a; letter-spacing: -.02em; margin-top: .6rem; }
    .auth-tag { font-size: .72rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: #94a3b8; margin-top: .15rem; }
    .auth-card { width: 100%; max-width: 27rem; background: #fff; border: 1px solid #e8edf6; border-radius: 1.25rem; padding: 2rem; box-shadow: 0 18px 48px -20px rgba(15,23,42,.3); }
    .auth-title { font-size: 1.6rem; font-weight: 800; color: #0f172a; }
    .auth-sub { color: #64748b; margin-top: .25rem; margin-bottom: 1.5rem; }
    .field { margin-bottom: 1.1rem; }
    .auth-error { background: #fef2f2; border: 1px solid #fecaca; color: #b91c1c; padding: .6rem .75rem; border-radius: .6rem; font-size: .85rem; margin-bottom: 1rem; }
    .auth-ok { background: #effcf9; border: 1px solid #cbfbef; color: #0f766e; padding: .8rem 1rem; border-radius: .75rem; font-size: .9rem; }
    .auth-foot { margin-top: 1.5rem; font-size: .9rem; color: #475569; text-align: center; }
    .auth-foot a { color: var(--accent-600); font-weight: 700; }
    .w-full { width: 100%; }
</style>

@code {
    [SupplyParameterFromQuery] public string? Token { get; set; }

    private readonly Model _model = new();
    private bool _busy;
    private bool _done;
    private string? _error;

    private async Task SubmitAsync()
    {
        _error = null;
        _busy = true;
        try
        {
            await Api.ResetPasswordAsync(Token!, _model.Password);
            _done = true;
        }
        catch (ApiException ex)
        {
            _error = ex.StatusCode == System.Net.HttpStatusCode.BadRequest
                ? "This reset link is invalid or has expired. Please request a new one."
                : ex.Message;
        }
        catch (Exception)
        {
            _error = "We couldn't reach the server. Please try again.";
        }
        finally
        {
            _busy = false;
        }
    }

    private sealed class Model
    {
        [Required(ErrorMessage = "A password is required.")]
        [StringLength(100, MinimumLength = 8, ErrorMessage = "Password must be at least 8 characters.")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Please confirm your password.")]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match.")]
        public string Confirm { get; set; } = "";
    }
}

@page "/student"
@implements IDisposable
@inject ApiClient Api
@inject AuthStateService Auth
@inject CurrentStudentState Current
@inject IUiText T

<PageTitle>@T["nav.today"] — cerdikMY</PageTitle>

<AppShell>
    <RoleGuard Roles="@(new[] { UserRole.Student, UserRole.Parent })">
        <div class="page-head">
            <div>
                <h1 class="page-title">@Greeting</h1>
                <p class="page-sub">@T["student.home.sub"]</p>
            </div>
            <div class="lang-toggle no-print" role="group" aria-label="Content language">
                @foreach (var lang in new[] { Language.BM, Language.EN })
                {
                    <button type="button" class="lang-btn @(_language == lang ? "active" : "")"
                            aria-pressed="@(_language == lang)" @onclick="() => SetLanguage(lang)">
                        @FilterLabels.Language(lang)
                    </button>
                }
            </div>
        </div>

        @if (_loading)
        {
            <p class="text-slate-500" role="status">@T["student.home.loading"]</p>
        }
        else if (_error is not null)
        {
            <div class="card" role="alert">
                <p class="text-rose-700">@_error</p>
                <button class="btn-secondary mt-4" @onclick="LoadAsync">@T["common.retry"]</button>
            </div>
        }
        else
        {
            @if (_streak is not null)
            {
                <section class="streak-card" aria-label="Streak and daily goal">
                    <div class="streak-flame">
                        <span class="flame-emoji" aria-hidden="true">@(_streak.CurrentStreak > 0 ? "🔥" : "✨")</span>
                        <span class="streak-text">
                            @(_streak.CurrentStreak > 0 ? string.Format(T["student.streak.days"], _streak.CurrentStreak) : T["student.streak.start"])
                        </span>
                        @if (_streak.LongestStreak > 1)
                        {
                            <span class="streak-best">@string.Format(T["student.streak.best"], _streak.LongestStreak)</span>
                        }
                    </div>
                    <div class="streak-goal">
                        @if (_streak.GoalMet)
                        {
                            <span class="goal-done">@T["student.streak.goal_met"]</span>
                        }
                        else
                        {
                            <span class="goal-text">@string.Format(T["student.streak.goal_progress"], _streak.TodayMinutes, _streak.GoalMinutes)</span>
                        }
                        <div class="goal-bar" role="meter" aria-valuemin="0" aria-valuemax="@_streak.GoalMinutes" aria-valuenow="@_streak.TodayMinutes">
                            <span style="width:@(GoalPct(_streak))%"></span>
                        </div>
                    </div>
                </section>
            }

            <section class="quick-stats" aria-label="Your progress">
                <div class="qstat">
                    <span class="qstat-label">@T["student.stat.points"]</span>
                    <span class="qstat-value">@(_student?.Points ?? 0)</span>
                </div>
                <div class="qstat">
                    <span class="qstat-label">@T["student.stat.mastery"]</span>
                    <span class="qstat-value">@(_progress is null ? "—" : $"{MasteryPct(_progress.OverallMastery)}%")</span>
                </div>
                <div class="qstat">
                    <span class="qstat-label">@T["student.stat.lessons_done"]</span>
                    <span class="qstat-value">@(_progress?.LessonsCompleted ?? 0)</span>
                </div>
                <div class="qstat">
                    <span class="qstat-label">@T["student.stat.badges"]</span>
                    <span class="qstat-value">@(_progress?.Badges.Count ?? 0)</span>
                </div>
            </section>

            <div class="home-grid">
                <section class="card" aria-labelledby="subjects-h">
                    <h2 id="subjects-h" class="card-title">@T["student.subjects.title"]</h2>
                    @if (_subjects.Count == 0)
                    {
                        <p class="text-slate-500">@T["student.subjects.empty"]</p>
                    }
                    else
                    {
                        <ul class="subject-list">
                            @foreach (var s in _subjects)
                            {
                                var prog = _progress?.Subjects.FirstOrDefault(p => p.SubjectId == s.Id);
                                <li class="subject-item">
                                    <div>
                                        <p class="subject-name">@s.Name</p>
                                        @if (prog is not null)
                                        {
                                            <p class="subject-sub">@prog.LessonsCompleted / @prog.TotalLessons @T["common.lessons"]</p>
                                        }
                                    </div>
                                    @if (prog is not null)
                                    {
                                        <MasteryBadge Band="prog.Band" ShowLabel="false" />
                                    }
                                </li>
                            }
                        </ul>
                    }
                    <a class="btn-secondary mt-4" href="/student/progress">@T["student.view_progress"]</a>
                </section>

                <aside class="home-side">
                    <section class="card cta-card">
                        <h2 class="card-title">@T["student.cta.title"]</h2>
                        <p class="text-slate-600 mb-4">@T["student.cta.sub"]</p>
                        <a class="btn-primary w-full" href="/student/tutor">@T["student.cta.tutor"]</a>
                        <a class="btn-secondary w-full mt-2" href="/student/progress">@T["student.cta.progress"]</a>
                    </section>

                    @if (_progress is { Badges.Count: > 0 })
                    {
                        <section class="card" aria-labelledby="badges-h">
                            <h2 id="badges-h" class="card-title">@T["student.badges.recent"]</h2>
                            <ul class="badge-list">
                                @foreach (var b in _progress.Badges.Take(5))
                                {
                                    <li>
                                        <span class="badge-icon" aria-hidden="true">@(b.Icon ?? "🏅")</span>
                                        <span>@b.Name</span>
                                    </li>
                                }
                            </ul>
                        </section>
                    }
                </aside>
            </div>
        }
    </RoleGuard>
</AppShell>

<style>
    .page-head { display: flex; flex-wrap: wrap; align-items: flex-end; justify-content: space-between; gap: 1rem; margin-bottom: 1.5rem; }
    .page-title { font-size: 1.6rem; font-weight: 700; color: #0f172a; }
    .page-sub { color: #64748b; margin-top: .25rem; }
    .lang-toggle { display: inline-flex; border: 1px solid #cbd5e1; border-radius: 9999px; overflow: hidden; }
    .lang-btn { border: 0; background: #fff; padding: .35rem .9rem; font-size: .8rem; font-weight: 600; color: #475569; cursor: pointer; }
    .lang-btn.active { background: var(--brand-600); color: #fff; }
    .lang-btn:focus-visible { outline: 2px solid var(--brand-500); outline-offset: -2px; }
    .quick-stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; margin-bottom: 1.5rem; }
    .qstat { background: #fff; border: 1px solid #e2e8f0; border-radius: .75rem; padding: 1rem; }
    .qstat-label { display: block; font-size: .75rem; color: #64748b; text-transform: uppercase; letter-spacing: .03em; }
    .qstat-value { font-size: 1.6rem; font-weight: 800; color: #0f172a; }
    .home-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
    .card-title { font-size: 1.1rem; font-weight: 700; color: #0f172a; margin-bottom: 1rem; }
    .subject-list, .badge-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: .6rem; }
    .subject-item { display: flex; align-items: center; justify-content: space-between; padding: .6rem .75rem; border: 1px solid #f1f5f9; border-radius: .5rem; }
    .subject-name { font-weight: 600; color: #1e293b; }
    .subject-sub { font-size: .78rem; color: #64748b; }
    .home-side { display: flex; flex-direction: column; gap: 1.5rem; }
    .badge-list li { display: flex; align-items: center; gap: .5rem; font-size: .9rem; }
    .w-full { width: 100%; }
    .streak-card { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1rem; background: linear-gradient(120deg, #fff7ed, #fff); border: 1px solid #fed7aa; border-radius: .9rem; padding: 1rem 1.25rem; margin-bottom: 1.5rem; }
    .streak-flame { display: flex; align-items: center; gap: .6rem; }
    .flame-emoji { font-size: 1.8rem; line-height: 1; }
    .streak-text { font-size: 1.1rem; font-weight: 800; color: #9a3412; }
    .streak-best { font-size: .75rem; font-weight: 600; color: #c2640a; background: #ffedd5; border-radius: 9999px; padding: .15rem .55rem; }
    .streak-goal { min-width: 12rem; flex: 1 1 12rem; }
    .goal-text, .goal-done { display: block; font-size: .8rem; font-weight: 700; color: #475569; margin-bottom: .3rem; }
    .goal-done { color: #15803d; }
    .goal-bar { background: #fde6cf; border-radius: 9999px; height: .5rem; overflow: hidden; }
    .goal-bar span { display: block; height: 100%; background: #f97316; border-radius: 9999px; }
    @@media (min-width: 640px) { .quick-stats { grid-template-columns: repeat(4, 1fr); } }
    @@media (min-width: 1024px) { .home-grid { grid-template-columns: 2fr 1fr; } }
</style>

@code {
    private StudentSummaryDto? _student;
    private ProgressDto? _progress;
    private StudentStreakDto? _streak;
    private IReadOnlyList<SubjectDto> _subjects = Array.Empty<SubjectDto>();
    private Language _language = Language.BM;
    private bool _loading = true;
    private string? _error;

    private string Greeting => string.Format(T["student.greeting"], _student?.DisplayName ?? Auth.User?.FullName ?? T["student.you"]);

    protected override async Task OnInitializedAsync()
    {
        Current.OnChange += OnStudentChanged;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _student = ResolveStudent();
            if (_student is not null) _language = _student.PrimaryLanguage;

            var studentId = _student?.Id ?? Auth.User?.StudentId;
            if (studentId is null)
            {
                _error = T["common.no_student"];
                return;
            }

            _progress = await Api.GetStudentProgressAsync(studentId.Value);
            _streak = await Api.GetStreakAsync(studentId.Value);

            var filter = _student is null
                ? new CurriculumFilter()
                : new CurriculumFilter(Level: _student.Level, SchoolType: _student.SchoolType,
                    Language: _language, DlpMode: _student.DlpMode);
            _subjects = await Api.GetSubjectsAsync(filter);
        }
        catch (ApiException ex)
        {
            _error = ex.Message;
        }
        catch (Exception)
        {
            _error = T["student.home.error"];
        }
        finally
        {
            _loading = false;
        }
    }

    private StudentSummaryDto? ResolveStudent()
    {
        if (Current.Student is not null) return Current.Student;
        Current.EnsureDefault(Auth.Students);
        return Current.Student
            ?? Auth.Students.FirstOrDefault(s => s.Id == Auth.User?.StudentId)
            ?? Auth.Students.FirstOrDefault();
    }

    private async void OnStudentChanged()
    {
        await LoadAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task SetLanguage(Language lang)
    {
        if (_language == lang) return;
        _language = lang;
        await LoadAsync();
    }

    private static int MasteryPct(double v) => (int)Math.Round(v * (v <= 1 ? 100 : 1));

    private static int GoalPct(StudentStreakDto s) =>
        s.GoalMinutes <= 0 ? 100 : Math.Min(100, (int)Math.Round(100.0 * s.TodayMinutes / s.GoalMinutes));

    public void Dispose() => Current.OnChange -= OnStudentChanged;
}

@implements IDisposable
@inject AuthStateService Auth

<nav class="space-y-1" aria-label="Primary">
    @foreach (var item in VisibleItems())
    {
        <NavLink class="nav-link" href="@item.Href"
                 Match="@(item.Href == "/" ? NavLinkMatch.All : NavLinkMatch.Prefix)">
            <span aria-hidden="true" class="nav-icon">@item.Icon</span>
            <span>@item.Label</span>
        </NavLink>
    }
</nav>

<style>
    .nav-link {
        display: flex;
        align-items: center;
        gap: .65rem;
        padding: .6rem .75rem;
        border-radius: .625rem;
        font-size: .9rem;
        font-weight: 600;
        color: #475569;
        border-left: 3px solid transparent;
    }
    .nav-link:hover { background: #f3f6fc; color: #1d4ed8; }
    .nav-link.active { background: var(--brand-50); color: var(--brand-700); border-left-color: var(--brand-600); }
    .nav-link:focus-visible { outline: 2px solid var(--brand-300); outline-offset: 2px; }
    .nav-icon { width: 1.25rem; text-align: center; }
</style>

@code {
    private IEnumerable<NavEntry> VisibleItems() => NavRegistry.For(Auth.Role);

    protected override void OnInitialized() => Auth.OnChange += StateHasChanged;

    public void Dispose() => Auth.OnChange -= StateHasChanged;
}

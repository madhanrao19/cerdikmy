@implements IDisposable
@inject AuthStateService Auth

<nav class="space-y-1" aria-label="Primary">
    @foreach (var item in VisibleItems())
    {
        <NavLink class="nav-link" href="@item.Href"
                 Match="@(item.Href == "/" ? NavLinkMatch.All : NavLinkMatch.Prefix)">
            <span aria-hidden="true" class="nav-icon">@item.Icon</span>
            <span>@item.Label</span>
        </NavLink>
    }
</nav>

<style>
    .nav-link {
        display: flex;
        align-items: center;
        gap: .6rem;
        padding: .55rem .75rem;
        border-radius: .5rem;
        font-size: .9rem;
        font-weight: 500;
        color: #cbd5e1;
    }
    .nav-link:hover { background: rgba(255,255,255,.08); color: #fff; }
    .nav-link.active { background: var(--brand-600); color: #fff; }
    .nav-link:focus-visible { outline: 2px solid var(--brand-300); outline-offset: 2px; }
    .nav-icon { width: 1.25rem; text-align: center; }
</style>

@code {
    private sealed record NavItem(string Href, string Label, string Icon, UserRole[] Roles);

    private static readonly NavItem[] AllItems =
    [
        // Parent
        new("/parent", "Dashboard", "🏠", [UserRole.Parent]),
        new("/parent/plan", "Study plans", "🗓️", [UserRole.Parent]),
        new("/parent/billing", "Billing", "💳", [UserRole.Parent]),
        new("/parent/flags", "Safety flags", "🚩", [UserRole.Parent]),
        // Student
        new("/student", "Today", "🏠", [UserRole.Student]),
        new("/student/tutor", "AI Tutor", "💬", [UserRole.Student]),
        new("/student/progress", "Progress", "📈", [UserRole.Student]),
        // Admin
        new("/admin", "Analytics", "📊", [UserRole.Admin, UserRole.ContentAdmin]),
        new("/admin/users", "Users", "👥", [UserRole.Admin]),
        new("/admin/content", "Content", "📚", [UserRole.Admin, UserRole.ContentAdmin]),
        new("/admin/curriculum", "Curriculum", "🧭", [UserRole.Admin, UserRole.ContentAdmin]),
        new("/admin/moderation", "Moderation", "🛡️", [UserRole.Admin, UserRole.SafetyReviewer]),
        new("/admin/payments", "Payments", "🧾", [UserRole.Admin]),
    ];

    private IEnumerable<NavItem> VisibleItems()
    {
        var role = Auth.Role;
        if (role is null) return Array.Empty<NavItem>();
        return AllItems.Where(i => i.Roles.Contains(role.Value));
    }

    protected override void OnInitialized() => Auth.OnChange += StateHasChanged;

    public void Dispose() => Auth.OnChange -= StateHasChanged;
}
